package coffee;

public class PalkCoffee extends Coffee{

	PalkCoffee(int price) {
		super(price);
		
	}
	
	
	@Override	
	void pay(int money) {
		this.money=money;
		if (price>money) {
			System.out.println("공차 : 커피제공이 어렵습니다.");
		}else {
			System.out.println("공차 : 커피가 제공되었습니다.");
		}
	}
	
	@Override	
	public String toString() {
		String result="공차 가격 : "+price+", 공차 입금액 : "+money;
		return result;		
	}

	
}
