	void add(Goods goods) {
		this.list.add(goods);
	}

//	장바구니에 담긴 모든 상품의 가격의 합을 출력
	int print() {
		int sum=0;
		for (int i = 0; i < list.size(); i++) {
			Goods g = (Goods) list.get(i);
			System.out.println("상품명 : " + g.getName() + "\t가격 : " + g.getPrice());
			sum += g.getPrice();
		}
		System.out.println("---------------------");
