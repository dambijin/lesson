package coffee;

public class Mega extends Coffee{

	
	Mega(int price) {
		super(price);
	}

	int money;
	@Override	
	void pay(int money) {
		this.money=money;
		if (price>money) {
			System.out.println("메가커퓌 : 꺼져");
		}else {
			System.out.println("메가커퓌 : 아주좋아 커피머겅");
		}
	}
	
	@Override	
	public String toString() {
		String result="메가커피가격 : "+price+", 메가커피 입금액 : "+money;
		
		return result;		
	}
	
}
